<Window x:Class="MasterPolApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер Пол - Вход в систему" 
        Height="480" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Resources/Мастер пол.png">

    <Grid Background="#F4E8D3" Margin="-19,0,-26,-82">
        <Grid.RowDefinitions>
            <RowDefinition Height="142*"/>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="81*"/>
            <RowDefinition Height="43*"/>
        </Grid.RowDefinitions>
        <Border Background="#FFFFFF" CornerRadius="15" Margin="0,22,0,0" Padding="30" Grid.RowSpan="4" Height="502" VerticalAlignment="Top" HorizontalAlignment="Center" Width="494">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ЛОГОТИП - Image вместо Border с текстом -->
                <Image Grid.Row="0" 
                       Source="/Resources/Мастер пол.png"
                       Width="80" 
                       Height="80"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"
                       Stretch="Uniform"/>

                <TextBlock Grid.Row="1" Text="Вход в систему" FontSize="22" 
                           FontWeight="SemiBold" Foreground="#333333" 
                           HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <!-- Логин -->
                <StackPanel Grid.Row="2" Margin="0,8">
                    <TextBlock Text="Логин" FontSize="13" Foreground="#666666" Margin="0,0,0,8"/>
                    <TextBox x:Name="txtUsername" Height="38" Padding="10,8" 
                             FontSize="14" BorderBrush="#D0C8B8" BorderThickness="1"/>
                </StackPanel>

                <!-- Пароль -->
                <StackPanel Grid.Row="3" Margin="0,8">
                    <TextBlock Text="Пароль" FontSize="13" Foreground="#666666" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="txtPassword" Height="38" Padding="10,8" 
                                 FontSize="14" BorderBrush="#D0C8B8" BorderThickness="1"/>
                </StackPanel>

                <!-- Кнопка входа -->
                <Button Grid.Row="4" Content="Войти" Click="LoginButton_Click"
                        Margin="0,17,0,8" Height="45" FontSize="15" FontWeight="SemiBold"
                        Background="#67BA80" Foreground="White" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>