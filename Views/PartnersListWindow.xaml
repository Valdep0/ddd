<Page x:Class="MasterPolApp.Views.PartnersListWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Список партнеров" Background="#FFFFFF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Партнеры компании" FontSize="22" FontWeight="SemiBold" Foreground="#333333"/>

        <!-- Панель поиска и фильтрации -->
        <Border Grid.Row="1" Background="#F4E8D3" CornerRadius="10" Padding="15" Margin="0,15,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" Width="250" Height="35" Padding="10,8" FontSize="14"
                             BorderBrush="#D0C8B8" BorderThickness="1" ToolTip="Поиск по названию, типу или директору">
                        <TextBox.Resources>
                            <VisualBrush x:Key="Hint" TileMode="None" AlignmentX="Left" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Text="🔍 Поиск..." Foreground="#999999" FontSize="13"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </TextBox.Resources>
                        <TextBox.Text>
                            <Binding RelativeSource="{RelativeSource Self}" Path="Text" 
                                     UpdateSourceTrigger="PropertyChanged" Delay="500"/>
                        </TextBox.Text>
                    </TextBox>
                    <Button Content="Поиск" Click="Search_Click" Width="80" Height="35" Margin="10,0,0,0"
                            Background="#67BA80" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Сбросить" Click="ResetSearch_Click" Width="80" Height="35" Margin="10,0,0,0"
                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button Grid.Column="1" Content="+ Добавить партнера" Click="AddPartnerButton_Click"
                        Width="170" Height="35" Background="#67BA80" Foreground="White" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Статистика -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="txtStats" FontSize="12" Foreground="#666666"/>
        </StackPanel>

        <!-- Список партнеров -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PartnersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Margin="0,0,0,10" 
                                Padding="15" BorderBrush="#D0C8B8" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Тип и название -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#67BA80" CornerRadius="10" Padding="8,3">
                                        <TextBlock Text="{Binding partner_type}" FontSize="11" 
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text=" " FontSize="14"/>
                                    <TextBlock Text="{Binding name}" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                                </StackPanel>

                                <!-- Скидка -->
                                <Border Grid.Row="0" Grid.Column="1" Background="#3498DB" CornerRadius="15" Padding="12,6">
                                    <TextBlock Text="{Binding DiscountPercent, StringFormat='Скидка: {0}%'}" 
                                               FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                </Border>

                                <!-- Директор -->
                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                           Text="{Binding director, StringFormat='👨‍💼 Директор: {0}'}" 
                                           FontSize="13" Foreground="#666666" Margin="0,0,0,4"/>

                                <!-- Телефон -->
                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                           Text="{Binding phone, StringFormat='📞 Тел: {0}'}" 
                                           FontSize="13" Foreground="#666666" Margin="0,0,0,4"/>

                                <!-- Email -->
                                <TextBlock Grid.Row="3" Grid.Column="0" 
                                           Text="{Binding email, StringFormat='✉ Email: {0}'}" 
                                           FontSize="13" Foreground="#666666" Margin="0,0,0,4"/>

                                <!-- Рейтинг и продажи -->
                                <WrapPanel Grid.Row="4" Grid.Column="0" Margin="0,8,0,0">
                                    <TextBlock Text="{Binding rating, StringFormat='⭐ Рейтинг: {0}'}" 
                                               FontSize="12" Foreground="#666666" Margin="0,0,20,0"/>
                                    <TextBlock Text="{Binding TotalSalesQuantity, StringFormat='📊 Продажи: {0:N0} м²'}" 
                                               FontSize="12" Foreground="#666666"/>
                                </WrapPanel>

                                <!-- Кнопки действий -->
                                <StackPanel Grid.Row="1" Grid.RowSpan="4" Grid.Column="1" 
                                            Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="✏ Редактировать" Click="EditPartner_Click" Tag="{Binding}"
                                            Width="110" Height="32" Margin="0,0,10,0" FontSize="12"
                                            Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="📜 История продаж" Click="ViewHistory_Click" Tag="{Binding}"
                                            Width="120" Height="32" FontSize="12"
                                            Background="#67BA80" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>