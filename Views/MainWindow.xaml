<Window x:Class="MasterPolApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Мастер Пол - Система управления" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/Мастер пол.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с меню -->
        <Border Grid.Row="0" Background="#2C3E50">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ЛОГОТИП -->
                <Image Grid.Column="0" 
                       Source="/Resources/Мастер пол.png"
                       Width="40" 
                       Height="40"
                       Margin="0,0,15,0"
                       Stretch="Uniform"/>

                <!-- МЕНЮ НАВИГАЦИИ -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Партнеры" Click="NavigateToPartners" 
                            Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                    <Button Content="Продукция" Click="NavigateToProducts" 
                            Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                    <Button Content="Склад" Click="NavigateToMaterials" 
                            Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                    <Button Content="Производство" Click="NavigateToProduction" 
                            Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                    <Button Content="Сотрудники" Click="NavigateToEmployees" 
                            Style="{StaticResource NavButtonStyle}" Margin="0,0,5,0"/>
                </StackPanel>

                <!-- ИНФОРМАЦИЯ О ПОЛЬЗОВАТЕЛЕ -->
                <Border Grid.Column="3" Background="#34495E" CornerRadius="15" 
                        Padding="12,5" Margin="0,0,15,0" HorizontalAlignment="Right">
                    <TextBlock x:Name="txtUserInfo" FontSize="12" Foreground="White" 
                               VerticalAlignment="Center"/>
                </Border>

                <!-- КНОПКА ВЫХОДА -->
                <Button Grid.Column="4" Content="Выйти" Click="LogoutButton_Click"
                        Width="90" Height="35" Background="#E74C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ОСНОВНОЕ СОДЕРЖИМОЕ -->
        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>

        <!-- НИЖНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="© 2026 Мастер Пол. Система управления предприятием" 
                       FontSize="11" Foreground="#666666"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>