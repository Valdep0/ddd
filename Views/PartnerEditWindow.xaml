<Window x:Class="MasterPolApp.Views.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование партнера" 
        Height="650" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F4E8D3">
        <Border Background="#FFFFFF" CornerRadius="15" Margin="20" Padding="25">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="TitleText" Text="Редактирование партнера" 
                               FontSize="22" FontWeight="SemiBold" Foreground="#333333" Margin="0,0,0,15"/>

                    <!-- Тип партнера -->
                    <StackPanel Grid.Row="1" Margin="0,8">
                        <TextBlock Text="Тип партнера *" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmbPartnerType" Height="38" FontSize="14">
                            <ComboBoxItem Content="ЗАО"/>
                            <ComboBoxItem Content="ООО"/>
                            <ComboBoxItem Content="ПАО"/>
                            <ComboBoxItem Content="ОАО"/>
                            <ComboBoxItem Content="ИП"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Наименование -->
                    <StackPanel Grid.Row="2" Margin="0,8">
                        <TextBlock Text="Наименование *" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtName" Height="38" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1"/>
                        <TextBlock x:Name="errorName" Foreground="#E74C3C" FontSize="11" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Директор -->
                    <StackPanel Grid.Row="3" Margin="0,8">
                        <TextBlock Text="ФИО директора" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtDirector" Height="38" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1"/>
                    </StackPanel>

                    <!-- Телефон -->
                    <StackPanel Grid.Row="4" Margin="0,8">
                        <TextBlock Text="Телефон" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtPhone" Height="38" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1"/>
                        <TextBlock x:Name="errorPhone" Foreground="#E74C3C" FontSize="11" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Email -->
                    <StackPanel Grid.Row="5" Margin="0,8">
                        <TextBlock Text="Email" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtEmail" Height="38" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1"/>
                        <TextBlock x:Name="errorEmail" Foreground="#E74C3C" FontSize="11" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Юридический адрес -->
                    <StackPanel Grid.Row="6" Margin="0,8">
                        <TextBlock Text="Юридический адрес" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtAddress" Height="80" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- ИНН -->
                    <StackPanel Grid.Row="7" Margin="0,8">
                        <TextBlock Text="ИНН" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtInn" Height="38" Padding="10,8" FontSize="14"
                                 BorderBrush="#D0C8B8" BorderThickness="1" MaxLength="12"/>
                        <TextBlock x:Name="errorInn" Foreground="#E74C3C" FontSize="11" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Рейтинг -->
                    <StackPanel Grid.Row="8" Margin="0,8">
                        <TextBlock Text="Рейтинг (0-100)" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <Slider x:Name="sliderRating" Minimum="0" Maximum="100" TickFrequency="1" 
                                IsSnapToTickEnabled="True" Height="30"/>
                        <TextBlock x:Name="txtRatingValue" Text="0" HorizontalAlignment="Center" 
                                   Margin="0,8,0,0" FontSize="14" Foreground="#333333"/>
                    </StackPanel>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,10">
                        <Button Content="Сохранить" Click="SaveButton_Click"
                                Width="110" Height="40" Margin="0,0,15,0" FontSize="14" FontWeight="SemiBold"
                                Background="#67BA80" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Отмена" Click="CancelButton_Click"
                                Width="110" Height="40" FontSize="14" FontWeight="SemiBold"
                                Background="Transparent" Foreground="#333333" BorderBrush="#D0C8B8" 
                                BorderThickness="1" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>